APP_NAME=Laracord
APP_ENV=development
# Timezone used by the app/config layer (timestamps are stored UTC regardless).
APP_TIMEZONE=UTC

# Discord
DISCORD_TOKEN=
DISCORD_GUILD_ID=
BANS_CHANNEL_ID=
# Channel for the live online-players roster (a single message refreshed in place).
# Leave UNSET to disable the feature entirely (the notifier safely no-ops).
CONNECTIONS_CHANNEL_ID=
# How often the roster message is refreshed, in minutes. Default 5 (min 1).
CONNECTIONS_REFRESH_MINUTES=5
# Set to false to disable the roster while keeping the channel configured. Default true.
CONNECTIONS_ENABLED=true

# Nitrado
NITRADO_TOKEN=
NITRADO_SERVICE_ID=

# Admin
ADMIN_ROLE_ID=

# Behavior
BAN_DURATION_HOURS=12
ADM_BACKFILL_BUDGET=15
# When true, record intended bans in the DB but make NO Nitrado/Discord writes.
BAN_DRY_RUN=false

# Bounty (all optional; shown with their code defaults — see config/bounty.php).
# Token awards from bounty kills are DB-only and fire even when BAN_DRY_RUN=true.
BOUNTY_ACTIVITY_WINDOW_HOURS=48
BOUNTY_MIN_PLAYTIME_HOURS=2
BOUNTY_MOVE_MARGIN_MIN=5
BOUNTY_ASSOC_WINDOW_DAYS=14
# 0 = keep position rows forever (no pruning).
BOUNTY_POSITION_RETENTION_DAYS=0
BOUNTY_ASSOC_RADIUS_M=150
BOUNTY_ASSOC_THRESHOLD=0.45
# Association signal weights (should sum to 1).
BOUNTY_ASSOC_WEIGHT_PROX=0.55
BOUNTY_ASSOC_WEIGHT_COPRES=0.35
BOUNTY_ASSOC_WEIGHT_KILLG=0.10
BOUNTY_SYNC_WINDOW_MIN=3
BOUNTY_TOKEN_REWARD=1
# Announcements channel; falls back to BANS_CHANNEL_ID when unset.
BOUNTY_CHANNEL_ID=

# Leaderboard (all optional; shown with their code defaults — see config/leaderboard.php).
# Set LEADERBOARD_CHANNEL_ID to enable; leave unset to disable entirely (no-ops safely).
LEADERBOARD_ENABLED=true
LEADERBOARD_CHANNEL_ID=
LEADERBOARD_REFRESH_MINUTES=15
LEADERBOARD_TOP_COUNT=5

# Database
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# Framework knobs (optional; code defaults shown).
DISCORD_BOT_DESCRIPTION="The Laracord Discord Bot."
DISCORD_COMMAND_PREFIX="!"
HTTP_SERVER=:8080
LOG_CHANNEL=stderr
LOG_LEVEL=warning

TZ=UTC

# --- Lifecycle: births + eulogies + playtime-gated bans ---
LIFECYCLE_ENABLED=true
LIFE_GRACE_MINUTES=5            # a life counts (birth/eulogy) after this much playtime
BAN_MIN_PLAYTIME_MINUTES=60     # only ban a death after this much playtime
LIFECYCLE_MAX_AGE_MINUTES=30    # freshness gate to suppress post-downtime backlog
BIRTHS_CHANNEL_ID=              # unset => no birth posts
EULOGY_CHANNEL_ID=              # unset => no eulogy posts (replaces the old death feed)

# OpenRouter (LLM) — unset key => every post uses the canned fallback automatically
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=20
OPENROUTER_MAX_TOKENS=900
OPENROUTER_TEMPERATURE=1.0

# Hit tracking — record weapon hits for associate detection scoring
HIT_TRACKING_ENABLED=true

# Weekly Newspaper Tribune — Friday highlights digest
NEWSPAPER_ENABLED=true
NEWSPAPER_CHANNEL_ID=
NEWSPAPER_PUBLISH_DOW=5
NEWSPAPER_PUBLISH_HOUR_UTC=22
