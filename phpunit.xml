<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         bootstrap="vendor/autoload.php" colors="true">
    <testsuites>
        <testsuite name="Unit"><directory>tests/Unit</directory></testsuite>
        <testsuite name="Feature"><directory>tests/Feature</directory></testsuite>
    </testsuites>
    <php>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="APP_ENV" value="testing"/>
        <!-- Pin bounty config defaults so config-assertion tests stay deterministic
             regardless of the developer/operator .env (which legitimately tunes these). -->
        <env name="BOUNTY_ACTIVITY_WINDOW_HOURS" value="48"/>
        <env name="BOUNTY_ASSOC_THRESHOLD" value="0.45"/>
        <env name="BOUNTY_ASSOC_WEIGHT_PROX" value="0.55"/>
        <env name="BOUNTY_ASSOC_WEIGHT_COPRES" value="0.35"/>
        <env name="BOUNTY_ASSOC_WEIGHT_KILLG" value="0.10"/>
        <env name="BOUNTY_POSITION_RETENTION_DAYS" value="0"/>
        <env name="CONNECTIONS_ENABLED" value="true"/>
        <env name="CONNECTIONS_REFRESH_MINUTES" value="5"/>
        <env name="DEATH_FEED_MAX_AGE_MINUTES" value="10"/>
        <env name="LEADERBOARD_ENABLED" value="true"/>
        <env name="LEADERBOARD_REFRESH_MINUTES" value="15"/>
        <env name="LEADERBOARD_TOP_COUNT" value="5"/>
    </php>
</phpunit>
